# Copy to .env and fill in your key, then `docker compose up`.
# Gemma g2p endpoint (OpenAI-compatible optional, set to preferred Gemma server). Optional — if unset, the app runs on
# the eSpeak floor. Do NOT include /chat/completions in the base URL.
# --- Pronunciation model (OpenAI-compatible g2p endpoint) ---

# Option A — Gemma 4 for richest multilingual pronunciations:
GEMMA_BASE_URL=https://openrouter.ai/api/v1
GEMMA_MODEL=google/gemma-4-31b-it
GEMMA_API_KEY=

# Option B — runs the g2p pipeline on AMD Instinct GPUs (Fireworks serverless):
# GEMMA_BASE_URL=https://api.fireworks.ai/inference/v1
# GEMMA_MODEL=accounts/fireworks/models/glm-5p2
# GEMMA_API_KEY=fw_...

# Optional overrides:
ORGANIZER_USERNAME=organizer
ORGANIZER_PASSWORD=changeme