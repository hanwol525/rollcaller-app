# RollCaller backend environment template.
# Copy to .env and fill in real values. Only DATABASE_URL / ORGANIZER_* are
# required to boot; everything else has a working default.

# --- Database ---
# SQLite for local dev; override for prod.
DATABASE_URL=sqlite:///./rollcaller.db

# --- Storage ---
# "filesystem" for dev, "minio" for prod (swappable in this one file).
STORAGE_BACKEND=filesystem
STORAGE_FS_ROOT=./blobstore
# MinIO / S3 (used only when STORAGE_BACKEND=minio):
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=rollcaller
# S3_SECURE=false

# --- Auth ---
ORGANIZER_USERNAME=organizer
ORGANIZER_PASSWORD=changeme
SESSION_SECRET=dev-secret-change-in-production

# --- Media ---
MEDIA_BASE_URL=/media

# --- Gemma g2p fallback (optional; prep-clips only, never live) ---
# OpenAI-compatible endpoint behind the g2p fallback. Fireworks today; the
# partner repoints GEMMA_BASE_URL / GEMMA_MODEL at their self-hosted AMD/vLLM
# Gemma endpoint later — same env vars, zero code change.
# If any of the three is unset, gemma_ipa() returns None immediately and the
# eSpeak floor is used, so the app runs and demos before the AMD box exists.
GEMMA_BASE_URL=https://api.fireworks.ai/inference/v1
GEMMA_MODEL=accounts/fireworks/models/gemma-3-12b-it
GEMMA_API_KEY=replace